# Grime Guardians Environment Configuration
# Copy this to .env and fill in your actual values

# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_JOB_BOARD_CHANNEL_ID=1367338545802383401
DISCORD_OPS_LEAD_ID=your_ops_lead_discord_user_id
DISCORD_CHECKIN_CHANNEL_ID=your_checkin_channel_id

# High Level Integration
HIGHLEVEL_API_KEY=your_highlevel_api_key_here
HIGHLEVEL_PRIVATE_INTEGRATION=your_highlevel_private_integration_id
HIGHLEVEL_CALENDAR_ID=your_calendar_id
HIGHLEVEL_LOCATION_ID=your_location_id
DISABLE_HIGHLEVEL=false

# Gmail API Configuration for Multi-Account Monitoring
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/oauth/callback

# Email addresses to monitor (comma-separated)
# IMPORTANT: broberts111592@gmail.com is the Google Voice account (612-584-9396)
GMAIL_EMAILS=brandonr@grimeguardians.com,grimeguardianscleaning@gmail.com,broberts111592@gmail.com

# OpenAI API for AI responses
OPENAI_API_KEY=your_openai_api_key_here

# Webhook Configuration
WEBHOOK_SECRET=your_secure_webhook_secret
WEBHOOK_PORT=3000

# Notion Integration
NOTION_SECRET=your_notion_integration_token
NOTION_ATTENDANCE_DB_ID=your_attendance_database_id
NOTION_STRIKES_DB_ID=your_strikes_database_id
NOTION_CLEANER_PROFILES_DB_ID=your_cleaner_profiles_database_id

# Operations Team
OPS_LEAD_DISCORD_ID=1343301440864780291

# Database Configuration (for future PostgreSQL migration)
USE_POSTGRES=false
DUAL_WRITE=false
FALLBACK_TO_NOTION=true
VALIDATE_WRITES=false

# PostgreSQL Settings (for when you migrate)
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_DB=grime_guardians_ops
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432
POSTGRES_SSL=false

# Cost Monitoring
COST_MONITORING_ENABLED=true

# Development/Production Settings
NODE_ENV=development
