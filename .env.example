# Grime Guardians Environment Configuration
# Copy this to .env and fill in your actual values

# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_JOB_BOARD_CHANNEL_ID=1367338545802383401

# High Level Integration
HIGHLEVEL_PRIVATE_INTEGRATION=your_highlevel_api_token
HIGHLEVEL_CALENDAR_ID=your_calendar_id

# Webhook Configuration
WEBHOOK_SECRET=your_secure_webhook_secret
WEBHOOK_PORT=3000

# Notion Integration
NOTION_SECRET=your_notion_integration_token
NOTION_ATTENDANCE_DB_ID=your_attendance_database_id
NOTION_STRIKES_DB_ID=your_strikes_database_id
NOTION_CLEANER_PROFILES_DB_ID=your_cleaner_profiles_database_id

# Operations Team
OPS_LEAD_DISCORD_ID=1343301440864780291

# Database Configuration (for future PostgreSQL migration)
USE_POSTGRES=false
DUAL_WRITE=false
FALLBACK_TO_NOTION=true
VALIDATE_WRITES=false

# PostgreSQL Settings (for when you migrate)
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_DB=grime_guardians_ops
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432
POSTGRES_SSL=false

# Cost Monitoring
COST_MONITORING_ENABLED=true

# Development/Production Settings
NODE_ENV=development
